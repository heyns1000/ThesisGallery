# Environment Configuration Template for Fruitful Global Master Hub
# Copy this file to .env and fill in your actual values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for the application (default: 5000)
PORT=5000

# Development database URL (provided by Replit)
DATABASE_URL=your-database-url-here

# =============================================================================
# REPLIT AUTHENTICATION (Required for existing auth)
# =============================================================================

# Replit OAuth Configuration
REPL_ID=your-repl-id
REPLIT_DOMAINS=your-replit-domain.replit.dev
ISSUER_URL=https://replit.com/oidc
SESSION_SECRET=your-session-secret

# =============================================================================
# GOOGLE OAUTH AUTHENTICATION
# =============================================================================

# Google OAuth Configuration for Google Sign-In integration
# These credentials are provided by Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_PROJECT_ID=your-google-project-id-here

# Authorized origins (should match your current Replit domain)
AUTHORIZED_DOMAIN=your-replit-domain-here

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================

# Firebase Client Configuration (Frontend)
# Get these values from your Firebase project settings > General > Your apps > Web app config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Web Push VAPID Key (for notifications)
# Get this from Firebase Console > Project Settings > Cloud Messaging > Web configuration
VITE_FIREBASE_VAPID_KEY=your-vapid-key

# Firebase Admin SDK Configuration (Backend)
# Get these values from Firebase Console > Project Settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key content here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project-id.iam.gserviceaccount.com

# =============================================================================
# FIREBASE SETUP INSTRUCTIONS
# =============================================================================

# STEP 1: Create Firebase Project
# --------------------------------
# 1. Go to the Firebase Console (https://console.firebase.google.com/)
# 2. Click "Create a project" or select your existing project
# 3. Follow the setup wizard (you can disable Google Analytics if not needed initially)

# STEP 2: Enable Required Services
# ---------------------------------
# 1. Authentication:
#    - Go to Build > Authentication > Get started
#    - Enable sign-in methods you want to use (Email/Password, Google, etc.)
# 2. Firestore Database:
#    - Go to Build > Firestore Database > Create database
#    - Start in test mode for development (configure rules later)
# 3. Cloud Messaging (for push notifications):
#    - Go to Project Settings > Cloud Messaging
#    - This is automatically enabled
# 4. Analytics (optional but recommended):
#    - Go to Project Settings > Integrations > Google Analytics

# STEP 3: Get Frontend Configuration
# ----------------------------------
# 1. Go to Project Settings > General tab
# 2. Scroll down to "Your apps" section
# 3. Click the web app icon (</>) to add a web app
# 4. Register your app with a nickname (e.g., "Fruitful Global Hub")
# 5. Copy the firebaseConfig object values to VITE_FIREBASE_* variables above
#    - apiKey → VITE_FIREBASE_API_KEY
#    - authDomain → VITE_FIREBASE_AUTH_DOMAIN
#    - projectId → VITE_FIREBASE_PROJECT_ID
#    - storageBucket → VITE_FIREBASE_STORAGE_BUCKET
#    - messagingSenderId → VITE_FIREBASE_MESSAGING_SENDER_ID
#    - appId → VITE_FIREBASE_APP_ID
#    - measurementId → VITE_FIREBASE_MEASUREMENT_ID

# STEP 4: Get VAPID Key for Push Notifications
# ---------------------------------------------
# 1. Go to Project Settings > Cloud Messaging tab
# 2. Scroll down to "Web configuration" section
# 3. Click "Generate key pair" if no key exists
# 4. Copy the key to VITE_FIREBASE_VAPID_KEY variable above

# STEP 5: Get Backend Admin SDK Configuration
# --------------------------------------------
# 1. Go to Project Settings > Service accounts tab
# 2. Click "Generate new private key" button
# 3. Download the JSON file (keep it secure!)
# 4. Extract values from the JSON file:
#    - project_id → FIREBASE_PROJECT_ID
#    - private_key_id → FIREBASE_PRIVATE_KEY_ID
#    - private_key → FIREBASE_PRIVATE_KEY (keep the \n characters!)
#    - client_email → FIREBASE_CLIENT_EMAIL
#    - client_id → FIREBASE_CLIENT_ID
#    - client_x509_cert_url → FIREBASE_CLIENT_CERT_URL

# STEP 6: Configure Security Rules (Production)
# ----------------------------------------------
# 1. Go to Build > Firestore Database > Rules
# 2. Set up proper security rules based on your authentication
# 3. Go to Build > Storage > Rules (if using Storage)
# 4. Enable App Check for additional security (Project Settings > App Check)

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# AI Services
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_GENAI_API_KEY=your-google-ai-api-key

# Payment Processing
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Communication Services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# =============================================================================
# SECURITY NOTES & ENVIRONMENT GUIDANCE
# =============================================================================

# DEVELOPMENT ENVIRONMENT
# ------------------------
# ✅ Safe practices for development:
# - Use a separate Firebase project for development/testing
# - Enable Firestore in "test mode" initially (allows read/write access)
# - Use Firebase Emulator Suite for local development (optional)
# - Test mode security rules: allow read, write: if true;

# PRODUCTION ENVIRONMENT
# -----------------------
# 🔒 Critical security requirements:
# - Use a separate Firebase project for production
# - Configure proper Firestore security rules (restrict access)
# - Enable App Check to verify legitimate app requests
# - Use Firebase Authentication to control data access
# - Enable audit logging for compliance

# CREDENTIAL SECURITY
# -------------------
# ❌ NEVER do these:
# - Commit your .env file to version control (add .env to .gitignore)
# - Share Firebase private keys in emails, chats, or documents
# - Use production credentials in development
# - Hardcode credentials in source code

# ✅ ALWAYS do these:
# - Keep Firebase private keys secure and encrypted
# - Rotate keys regularly (every 3-6 months for production)
# - Use environment-specific projects (dev/staging/prod)
# - Monitor Firebase usage and billing alerts
# - Enable 2FA on your Firebase/Google account

# FIRESTORE SECURITY RULES EXAMPLES
# ----------------------------------
# Development (permissive - for testing only):
# rules_version = '2';
# service cloud.firestore {
#   match /databases/{database}/documents {
#     match /{document=**} {
#       allow read, write: if true;
#     }
#   }
# }

# Production (restrictive - requires authentication):
# rules_version = '2';
# service cloud.firestore {
#   match /databases/{database}/documents {
#     match /users/{userId} {
#       allow read, write: if request.auth != null && request.auth.uid == userId;
#     }
#     match /public/{document} {
#       allow read: if true;
#       allow write: if request.auth != null;
#     }
#   }
# }

# TROUBLESHOOTING
# ---------------
# If you see Firebase errors:
# 1. Check console logs for specific error messages
# 2. Verify all environment variables are set correctly
# 3. Ensure Firebase project has required services enabled
# 4. Check Firebase security rules aren't blocking requests
# 5. Verify API keys haven't been restricted or rotated

# Firebase services will gracefully degrade without credentials:
# - Authentication: Returns null user
# - Firestore: Operations will fail with clear error messages
# - Analytics: Events won't be tracked
# - Messaging: Push notifications disabled
# The application will continue working with reduced functionality.