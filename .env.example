# Environment Configuration Template for Fruitful Global Master Hub
# Copy this file to .env and fill in your actual values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for the application (default: 5000)
PORT=5000

# Development database URL (provided by Replit)
DATABASE_URL=your-database-url-here

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================

# Firebase Client Configuration (Frontend)
# Get these values from your Firebase project settings > General > Your apps > Web app config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Web Push VAPID Key (for notifications)
# Get this from Firebase Console > Project Settings > Cloud Messaging > Web configuration
VITE_FIREBASE_VAPID_KEY=your-vapid-key

# Firebase Admin SDK Configuration (Backend)
# Get these values from Firebase Console > Project Settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key content here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project-id.iam.gserviceaccount.com

# =============================================================================
# FIREBASE SETUP INSTRUCTIONS
# =============================================================================

# 1. Go to the Firebase Console (https://console.firebase.google.com/)
# 2. Create a new project or select your existing project
# 3. Enable Authentication, Firestore, Cloud Messaging, and Analytics
# 4. Go to Project Settings > General tab:
#    - Copy your web app config values to the VITE_FIREBASE_* variables above
# 5. Go to Project Settings > Cloud Messaging tab:
#    - Generate a web push certificate and copy the VAPID key
# 6. Go to Project Settings > Service accounts tab:
#    - Click "Generate new private key" and download the JSON file
#    - Copy the values from the JSON to the FIREBASE_* variables above
# 7. Important: Keep your private key secure and never commit it to version control

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# AI Services
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_GENAI_API_KEY=your-google-ai-api-key

# Payment Processing
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Communication Services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# =============================================================================
# SECURITY NOTES
# =============================================================================

# - Never commit your actual .env file to version control
# - Keep your Firebase private key secure
# - Rotate keys regularly for production environments
# - Use Firebase security rules to protect your data
# - Enable App Check for additional security in production